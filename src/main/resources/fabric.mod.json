{
	"schemaVersion": 1,
	"id": "bingus-auth",
	"version": "${version}",
	"name": "BingusAuth",
	"description": "Simple auth mod for 26.1 - password login for Java players, auto-login for Bedrock/Floodgate",
	"authors": [
		"_12354fdw"
	],
	"license": "MIT",
	"environment": "server",
	"entrypoints": {
		"main": [
			{
				"value": "org.goofylandproductions.Bingusauth",
				"adapter": "kotlin"
			}
		]
	},
	"mixins": [
		"bingus-auth.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.18.5",
		"minecraft": "~26.1",
		"java": ">=25",
		"fabric-api": "*",
		"fabric-language-kotlin": "*"
	},
	"suggests": {
		"floodgate": "*"
	}
}